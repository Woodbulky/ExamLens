# ============================================
# ExamLens — Backend Environment Variables
# ============================================
# All AI providers support multiple comma-separated API keys.
# Keys are rotated round-robin to distribute load and avoid rate limits.

# Groq API (Primary — fastest, used for classification & summaries)
# Get free keys at: https://console.groq.com/keys
# Add multiple keys separated by commas (no spaces):
GROQ_API_KEY=gsk_key1,gsk_key2,gsk_key3

# Cerebras API (Secondary — used for practice question generation)
# Get free keys at: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=csk_your-cerebras-key-here

# NVIDIA API (Last-resort fallback)
# Get free keys at: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your-nvidia-key-here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# CORS — frontend URL allowed to call this API
FRONTEND_URL=http://localhost:5173

# Environment
ENV=development
